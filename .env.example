# ─── Domain & Networking ─────────────────────────────────────
N8N_HOST=n8n.yourdomain.com
ACME_EMAIL=admin@yourdomain.com

# ─── Timezone ────────────────────────────────────────────────
TIMEZONE=Asia/Jerusalem

# ─── n8n Workers ─────────────────────────────────────────────
N8N_WORKER_REPLICAS=2

# ─── Database Passwords (for PostgreSQL init only) ───────────
# These must match the values in secrets/secrets.enc.yaml.
# They are only used during first PostgreSQL boot to create users.
# After init, PG stores hashed passwords internally.
N8N_DB_PASSWORD=
MEMORY_DB_PASSWORD=
AUDIT_DB_PASSWORD=

# ─── SOPS Age Key ────────────────────────────────────────────
# Path to age private key for decrypting secrets
# Default: ~/.config/sops/age/keys.txt
# SOPS_AGE_KEY_FILE=/path/to/keys.txt
